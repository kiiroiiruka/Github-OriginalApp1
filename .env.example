#ここれ他の共同制作者がenvファイルの中身をセットする際に
#どんな値をセットさせればいいのかがわかるようにさせることが可能
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Netlify Functions（サーバー側のみ。VITE_ プレフィックスは不要）
# Firebase トークン検証用（VITE_FIREBASE_API_KEY と同じ値）
FIREBASE_API_KEY=

# Firebase Admin（確認メール用リンク生成）
# Firebase Console → プロジェクト設定 → サービスアカウント → 新しい秘密鍵の生成
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 確認メール内リンクの戻り先（ローカルは http://localhost:8888）
APP_URL=http://localhost:8888

# メール送信用 SMTP（Gmail ならアプリパスワードを SMTP_PASS に設定）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
